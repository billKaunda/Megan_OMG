# ---------------------------------------------------------------------------
# Example environment configuration. Copy to `.env` and fill in real values:
#   cp .env.example .env
# `.env` is git-ignored — never commit real keys.
# ---------------------------------------------------------------------------

# === Backend / blockchain demo (existing app) ==============================
PORT=3002
NODE_ENV=development
BLOCKCHAIN_DIFFICULTY=2
BLOCKCHAIN_MINING_REWARD=100
INITIAL_MINER_ADDRESS=genesis-miner
SEED_DEMO_DATA=true
REACT_APP_API_URL=http://localhost:3002

# === Smart contract deployment (Foundry) ===================================
# Deployer private key. For local Anvil you can use its well-known account #0
# key; NEVER use a real-funds key here and never commit a populated .env.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# RPC endpoints (required for the matching --network).
SEPOLIA_RPC_URL=
MAINNET_RPC_URL=

# Etherscan API key — only needed when deploying with --verify.
ETHERSCAN_API_KEY=

# --- Token parameters (optional; sensible defaults applied if omitted) ------
# Amounts are in WHOLE tokens; the deploy layer scales them by 10**18.
TOKEN_NAME=Assessment Token
TOKEN_SYMBOL=AST
TOKEN_CAP=1000000
TOKEN_INITIAL_SUPPLY=100000
# Owner / initial holder. Defaults to the deployer address if left blank.
# TOKEN_OWNER=0x0000000000000000000000000000000000000000
